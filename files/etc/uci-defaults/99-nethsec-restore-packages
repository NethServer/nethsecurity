#
# Launch extra-packages restore in the background after a system upgrade.
# The script waits for WAN connectivity before attempting any opkg operations.
#

if grep -q -E '\w+\s+overlay$' /etc/backup/installed_packages.txt; then
    /usr/sbin/screen -dmS restore_packages /usr/sbin/ns-restore-extra-packages
fi

exit 0
