{
    "db_path": "${path_state_persistent}/db",
    "channels": {
        "default": {
            "enable": true,
            "db_name": "stats.db",
            "data_source": "aggregator",
            "purge_in_days": 2,
            "tables": [
                {
                    "name": "stats",
                    "columns": [
                        {
                            "name": "application_category_id",
                            "mapped": "application_category",
                            "type": "INTEGER"
                        },
                        {
                            "name": "application_id",
                            "mapped": "detected_application",
                            "type": "INTEGER"
                        },
                        {
                            "name": "application_name",
                            "mapped": "detected_application_name",
                            "type": "TEXT"
                        },
                        {
                            "name": "protocol_id",
                            "mapped": "detected_protocol",
                            "type": "INTEGER"
                        },
                        {
                            "name": "protocol_name",
                            "mapped": "detected_protocol_name",
                            "type": "TEXT"
                        },
                        {
                          "name": "internal",
                          "mapped": "internal",
                          "type": "TEXT"
                        },
                        {
                            "name": "ip_version",
                            "mapped": "ip_version",
                            "type": "INTEGER"
                        },
                        {
                            "name": "local_bytes",
                            "mapped": "local_bytes",
                            "type": "INTEGER"
                        },
                        {
                            "name": "local_ip",
                            "mapped": "local_ip",
                            "type": "TEXT"
                        },
                        {
                            "name": "local_origin",
                            "mapped": "local_origin",
                            "type": "TEXT"
                        },
                        {
                            "name": "other_bytes",
                            "mapped": "other_bytes",
                            "type": "INTEGER"
                        },
                        {
                            "name": "other_ip",
                            "mapped": "other_ip",
                            "type": "TEXT"
                        },
                        {
                            "name": "other_port",
                            "mapped": "other_port",
                            "type": "INTEGER"
                        },
                        {
                            "name": "other_type",
                            "mapped": "other_type",
                            "type": "TEXT"
                        },
                        {
                            "name": "protocol_category_id",
                            "mapped": "protocol_category",
                            "type": "INTEGER"
                        }
                    ]
                }
            ]
        }
    }
}
