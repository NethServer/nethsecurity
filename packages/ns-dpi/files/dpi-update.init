USE_PROCD=1
START=49

start_service() {
    procd_open_instance
    procd_set_param command "/usr/sbin/dpi-update"
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

reload_service()
{
    start
}

service_triggers() {
    procd_add_reload_trigger "dpi" "ns-plug"
}
